# Socrates - Environment variables
# Copiar este archivo a .env.local y rellenar los valores reales.
# .env.local NUNCA debe commitearse (esta en .gitignore).
# Estandar del investigador: validacion de config al startup, fallar rapido.

# ===========================================================================
# Supabase (D5: backend todo en uno + RLS dia uno)
# ===========================================================================
# Obtener de: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Service role: SOLO para jobs del backend, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-KEEP-SECRET

# Supabase DB URL (para migraciones locales con supabase CLI opcional)
# postgresql://postgres.PROJECT:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# ===========================================================================
# Anthropic (Claude Opus + Sonnet para A2, A3, A4, A7, A10, A11, A12)
# ===========================================================================
# Obtener de: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY

# Modelos fijos (versionados para reproducibilidad)
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# ===========================================================================
# OpenAI (GPT-4o para A1 - extraccion multimodal de PDFs)
# ===========================================================================
# Obtener de: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR-KEY
OPENAI_MODEL_VISION=gpt-4o

# ===========================================================================
# Orquestacion de jobs largos (D2: sin n8n, Trigger.dev o Inngest)
# ===========================================================================
# Decision final entre Trigger.dev e Inngest se toma en S3 (ingestion)
# Placeholder:
TRIGGER_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ===========================================================================
# App
# ===========================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Whitelist admin (D6: multi-usuario controlado)
# Email del admin inicial que puede invitar a otros aprendices
ADMIN_EMAIL=

# ===========================================================================
# Validacion
# ===========================================================================
# Socrates valida estas variables al startup via lib/env.ts
# Si falta una variable CRITICA, el proceso aborta con mensaje claro.
# Variables CRITICAS para arrancar el MVP-1:
#   - NEXT_PUBLIC_SUPABASE_URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
#   - ANTHROPIC_API_KEY
#   - OPENAI_API_KEY
#   - ADMIN_EMAIL
